{
    "name": "Tududi Development Environment",
    "dockerFile": "Dockerfile",
    "build": {
        "context": ".",
        "dockerfile": "Dockerfile.devcontainer"
    },
    "features": {
        // "ghcr.io/devcontainers/features/node:1": {
        //     "version": "22"
        // },
        // "ghcr.io/devcontainers/features/git:1": {}
        // "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "dbaeumer.markdown-preview-github-styles",
                "bradlc.vscode-tailwindcss",
                "ms-vscode.vscode-typescript-next",
                "formulahendry.auto-rename-tag",
                "streetsidesoftware.code-spell-checker",
                "bierner.markdown-mermaid",
                "github.vscode-pull-request-github"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.fixAll.eslint": "explicit"
                },
                "eslint.validate": [
                    "javascript",
                    "typescript",
                    "javascriptreact",
                    "typescriptreact"
                ],
                "files.associations": {
                    "*.ts": "typescript",
                    "*.tsx": "typescriptreact",
                    "*.js": "javascript",
                    "*.jsx": "javascriptreact"
                },
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "prettier.configPath": "./prettier.config.js",
                "files.exclude": {
                    "**/node_modules": true,
                    "**/dist": true,
                    "**/coverage": true
                }
            }
        }
    },
    // "remoteUser": "vscode",
    "forwardPorts": [3002, 8080],
    "portsAttributes": {
        "3002": {
            "onAutoForward": "silent",
            "label": "Backend API"
        },
        "8080": {
            "onAutoForward": "silent",
            "label": "Frontend"
        }
    },
    "postCreateCommand": "/app/.devcontainer/scripts/post-create.sh",
    "postStartCommand": "/app/.devcontainer/scripts/post-start.sh"
}
